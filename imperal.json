{
  "manifest_schema_version": 3,
  "sdk_version": "4.2.1",
  "app_id": "tg-bot",
  "version": "1.0.0",
  "name": "TG Bot Builder",
  "description": "Create and manage Telegram bots connected to Imperal. Build notification bots, AI assistants, and automated report delivery via Telegram.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": false,
  "capabilities": [],
  "tools": [
    {
      "name": "tg_bot",
      "description": "TG Bot Builder — create Telegram bots. ALWAYS use for: создать бота, настрой бота, добавь расписание уведомлений, отправь сообщение через бота, покажи ботов, удали бота, настрой уведомления в Telegram, привяжи бота, перепривяжи бота.",
      "scopes": [],
      "parameters": {
        "message": {
          "type": "string",
          "required": false
        },
        "kwargs": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "skeleton_refresh_tgbot_status",
      "description": "User Telegram bots — names, active status, link status",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "show_create_form",
      "description": "Navigate to bot creation wizard step 1 (BotFather instructions).",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.nav_create",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "show_step2_form",
      "description": "Navigate to bot creation wizard step 2 (token input form).",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.nav_step2",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "open_bot_detail",
      "description": "Open a specific bot's detail view in the panel.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_id": {
            "description": "Bot UUID",
            "title": "Bot Id",
            "type": "string"
          }
        },
        "required": [
          "bot_id"
        ],
        "title": "BotIdParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.nav_detail",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "list_bots",
      "description": "List all Telegram bots for this user.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.listed",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "create_bot",
      "description": "Create a new Telegram bot. Requires: name, token from @BotFather. mode defaults to standalone. owner_tg_id optional.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:bot"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "name": {
            "description": "Bot display name, e.g. 'Репорт Блога'",
            "title": "Name",
            "type": "string"
          },
          "token": {
            "description": "Telegram bot token from @BotFather",
            "title": "Token",
            "type": "string"
          },
          "system_prompt": {
            "default": "",
            "description": "AI persona and instructions",
            "title": "System Prompt",
            "type": "string"
          },
          "mode": {
            "default": "standalone",
            "description": "'standalone' or 'webbee'",
            "title": "Mode",
            "type": "string"
          },
          "owner_tg_id": {
            "default": "",
            "description": "Your Telegram user ID (optional, alternative to QR linking)",
            "title": "Owner Tg Id",
            "type": "string"
          }
        },
        "required": [
          "name",
          "token"
        ],
        "title": "CreateBotParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.created",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "delete_bot",
      "description": "Delete a Telegram bot permanently. Removes webhook and all schedules.",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "delete:bot"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to act on",
            "title": "Bot Name",
            "type": "string"
          }
        },
        "required": [
          "bot_name"
        ],
        "title": "BotNameParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.deleted",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "enable_bot",
      "description": "Enable a disabled Telegram bot.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:bot"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to act on",
            "title": "Bot Name",
            "type": "string"
          }
        },
        "required": [
          "bot_name"
        ],
        "title": "BotNameParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.updated",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "disable_bot",
      "description": "Disable a Telegram bot (stops responding to messages).",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:bot"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to act on",
            "title": "Bot Name",
            "type": "string"
          }
        },
        "required": [
          "bot_name"
        ],
        "title": "BotNameParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.updated",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "set_prompt",
      "description": "Update a bot's system prompt.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:bot"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name",
            "title": "Bot Name",
            "type": "string"
          },
          "system_prompt": {
            "description": "New system prompt text",
            "title": "System Prompt",
            "type": "string"
          }
        },
        "required": [
          "bot_name",
          "system_prompt"
        ],
        "title": "SetPromptParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.updated",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "relink_bot",
      "description": "Re-generate QR code and linking code for a bot.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:bot"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to act on",
            "title": "Bot Name",
            "type": "string"
          }
        },
        "required": [
          "bot_name"
        ],
        "title": "BotNameParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.updated",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "add_schedule",
      "description": "Add a scheduled notification to a bot. task_type: 'analytics_daily' (daily traffic), 'analytics_weekly' (weekly report), 'custom_message' (fixed text). cron_expr examples: '0 8 * * *' = 8am daily, '0 9 * * 1' = 9am every Monday.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "create:schedule"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to add schedule to",
            "title": "Bot Name",
            "type": "string"
          },
          "description": {
            "description": "Human-readable description of the schedule",
            "title": "Description",
            "type": "string"
          },
          "cron_expr": {
            "description": "Cron expression, e.g. '0 8 * * *' for 8am daily",
            "title": "Cron Expr",
            "type": "string"
          },
          "task_type": {
            "description": "'analytics_daily' | 'analytics_weekly' | 'custom_message'",
            "title": "Task Type",
            "type": "string"
          },
          "message": {
            "default": "",
            "description": "Message text for custom_message task type",
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "bot_name",
          "description",
          "cron_expr",
          "task_type"
        ],
        "title": "AddScheduleParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.schedule.created",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "remove_schedule",
      "description": "Remove a scheduled notification by schedule ID.",
      "action_type": "destructive",
      "chain_callable": true,
      "effects": [
        "delete:schedule"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "schedule_id": {
            "description": "Schedule UUID to remove",
            "title": "Schedule Id",
            "type": "string"
          }
        },
        "required": [
          "schedule_id"
        ],
        "title": "RemoveScheduleParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.schedule.deleted",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "list_schedules",
      "description": "List all schedules for a bot.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to act on",
            "title": "Bot Name",
            "type": "string"
          }
        },
        "required": [
          "bot_name"
        ],
        "title": "BotNameParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.schedule.listed",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "send_message",
      "description": "Send a message via a Telegram bot to its owner. Use when user asks to send a notification or test the bot. bot_name optional — uses default bot if not specified.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "send:message"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "text": {
            "description": "Message text to send",
            "title": "Text",
            "type": "string"
          },
          "bot_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Bot name — uses default if not specified",
            "title": "Bot Name"
          },
          "chat_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Target chat ID — uses owner_chat_id if not specified",
            "title": "Chat Id"
          }
        },
        "required": [
          "text"
        ],
        "title": "SendMessageParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.message.sent",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "test_bot",
      "description": "Send a test message via a bot to verify it is working.",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "send:message"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "bot_name": {
            "description": "Bot name to test",
            "title": "Bot Name",
            "type": "string"
          },
          "message": {
            "default": "Тест! Бот работает.",
            "description": "Test message to send",
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "bot_name"
        ],
        "title": "TestBotParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.message.sent",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "save_settings",
      "description": "Save TG Bot Builder settings (e.g. default bot ID for IPC).",
      "action_type": "write",
      "chain_callable": true,
      "effects": [
        "update:settings"
      ],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "default_bot_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Default bot ID for IPC notifications",
            "title": "Default Bot Id"
          }
        },
        "title": "SaveSettingsParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "tgbot.settings.saved",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    },
    {
      "name": "get_settings",
      "description": "Show TG Bot Builder extension settings.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {},
        "title": "EmptyParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "tg_bot"
    }
  ],
  "signals": [],
  "schedules": [],
  "required_scopes": [],
  "icon_size_bytes": 207,
  "webhooks": [
    {
      "path": "/tg-message",
      "method": "POST",
      "secret_header": ""
    }
  ],
  "exposed": [
    {
      "name": "send_message",
      "action_type": "read"
    }
  ],
  "lifecycle": {
    "health_check": {
      "interval_sec": 60
    }
  }
}